# ═══════════════════════════════════════════════════════════════
# Caddyfile — Reverse proxy for ResumeXray
# ═══════════════════════════════════════════════════════════════
# Caddy auto-provisions Let's Encrypt TLS.
# Cloudflare sits in front — "Full (strict)" SSL mode.
#
# Usage: sudo caddy run --config /app/infra/Caddyfile
# ═══════════════════════════════════════════════════════════════

resumexray.pro {
    # Brotli + gzip compression (§1.4)
    encode br gzip

    # Reverse proxy to Node.js
    reverse_proxy localhost:3000 {
        # Trust Cloudflare headers
        header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
        header_up X-Real-IP {http.request.header.CF-Connecting-IP}
        
        # Timeouts
        transport http {
            dial_timeout 5s
            read_timeout 120s    # SSE streams can be long-lived
            write_timeout 120s
        }
        
        # Health check for load balancing readiness
        health_uri /healthz
        health_interval 10s
        health_timeout 2s
    }

    # Cache static assets aggressively
    @static path /js/* /css/* /images/* /fonts/* *.ico *.webp *.avif *.woff2
    header @static Cache-Control "public, max-age=31536000, immutable"

    # No-cache for HTML (SPA)
    @html path / /dashboard /results/* /pricing /login
    header @html Cache-Control "no-cache, no-store, must-revalidate"

    # §9.6: Bypass Cloudflare cache for SSE streams
    @sse path /api/agent/stream/*
    header @sse Cache-Control "no-cache"
    header @sse X-Accel-Buffering "no"

    # Force HSTS (Caddy does this automatically, but explicit for clarity)
    header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

    # Max upload size (§3.8: defense-in-depth with multer)
    request_body {
        max_size 5MB
    }

    # §11.2: Prometheus metrics — localhost only (Caddy blocks external)
    @metrics path /metrics
    handle @metrics {
        # Only accessible from localhost
        @notLocal not remote_ip 127.0.0.1/8 ::1
        respond @notLocal 403
        reverse_proxy localhost:3000
    }

    # Structured access logs
    log {
        output file /var/log/caddy/resumexray.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}

# Redirect www to apex
www.resumexray.pro {
    redir https://resumexray.pro{uri} permanent
}
